{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VisionX",
  "version": "0.7.0",
  "identifier": "com.visionx.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VisionX",
        "label": "main",
        "width": 900,
        "height": 850,
        "minWidth": 600,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": {
      "resources/config.yaml": "config.yaml",
      "resources/tracker.yaml": "tracker.yaml",
      "resources/scripts/vision.py": "scripts/vision.py",
      "resources/scripts/report.py": "scripts/report.py",
      "resources/scripts/plate.py": "scripts/plate.py",
      "resources/scripts/plate_report.py": "scripts/plate_report.py",
      "resources/scripts/tracking.py": "scripts/tracking.py",
      "resources/scripts/stitch.py": "scripts/stitch.py",
      "resources/scripts/plate_core.py": "scripts/plate_core.py",
      "resources/scripts/face_shots.py": "scripts/face_shots.py",
      "resources/scripts/cross_match.py": "scripts/cross_match.py",
      "resources/scripts/match_report.py": "scripts/match_report.py"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/nickpolychronakis/VisionX/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYzNjc4QzAyMTQxQTE2M0EKUldRNkZob1VBb3huWTc1U1lpc0lKVG1FUzY1VFZUMm93akF1WlQzUUh6ME9oaHQrTWxTMzRtWHkK"
    }
  }
}
